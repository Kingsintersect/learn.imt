# Managed by deploy pipeline — proxies all traffic to Next.js on port 3700.
# This file is scoped to learn.imt.qverselearning.org only.
Options -Indexes
DirectoryIndex disabled

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Skip rewriting for .well-known (ACME/SSL challenges)
    RewriteRule ^\.well-known/ - [L]

    # WebSocket upgrade passthrough (required by Next.js)
    RewriteCond %{HTTP:Upgrade} websocket [NC]
    RewriteRule ^(.*)$ ws://127.0.0.1:3700/$1 [P,L]

    # Proxy /api/v1/* to remote backend
    RewriteRule ^api/v1/(.*)$ https://imt-orientation-api.qverselearning.org/api/v1/$1 [P,L]

    # Proxy all other requests to Next.js
    RewriteRule ^(.*)$ http://127.0.0.1:3700/$1 [P,L]
</IfModule>
